// Krit — skill-first LMS
// The primitive is the Skill. Paths/Lessons/Assessments are delivery.
// Evidence against skills is the product. All activity is an LRS event.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Identity & tenancy ─────────────────────────

model User {
  id            String   @id
  email         String   @unique
  name          String
  handle        String   @unique
  avatarUrl     String?
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships       Membership[]
  enrollments       Enrollment[]
  attempts          Attempt[]
  submissions       Submission[]
  evidence          Evidence[]
  credentials       IssuedCredential[]
  lrsEvents         LrsEvent[]
  tutorConversations TutorConversation[]
  skillStates       SkillState[]
  assignmentsAssigned Assignment[] @relation("AssignedBy")
  assignmentsReceived Assignment[] @relation("AssignedTo")

  @@index([email])
  @@index([handle])
}

enum WorkspaceKind {
  CORPORATE
  ACADEMY    // retail/creator-led
  PERSONAL
}

model Workspace {
  id          String        @id
  slug        String        @unique
  name        String
  kind        WorkspaceKind @default(CORPORATE)
  logoUrl     String?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  memberships         Membership[]
  paths               Path[]
  skills              Skill[]
  assessments         Assessment[]
  credentials         Credential[]
  assignments         Assignment[]
  roles               RoleProfile[]
}

enum Role {
  OWNER           // workspace owner
  ADMIN           // L&D admin
  MANAGER         // people manager (sees reports)
  AUTHOR          // content author
  INSTRUCTOR      // delivers live sessions, grades submissions
  LEARNER         // default
}

model Membership {
  id          String    @id
  userId      String
  workspaceId String
  role        Role      @default(LEARNER)
  managerId   String?   // people-manager hierarchy (self-referential through User)
  roleProfileId String?
  joinedAt    DateTime  @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roleProfile RoleProfile? @relation(fields: [roleProfileId], references: [id])

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

// Role architecture — corporate feature. Defines skills required for a role.
model RoleProfile {
  id          String   @id
  workspaceId String
  name        String   // "Senior Backend Engineer"
  description String?
  createdAt   DateTime @default(now())

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requirements  RoleRequirement[]
  memberships   Membership[]

  @@index([workspaceId])
}

model RoleRequirement {
  id            String   @id
  roleProfileId String
  skillId       String
  requiredLevel ProficiencyLevel

  roleProfile   RoleProfile @relation(fields: [roleProfileId], references: [id], onDelete: Cascade)
  skill         Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([roleProfileId, skillId])
}

// ───────────────────────── Skill graph ─────────────────────────

enum ProficiencyLevel {
  NOVICE        // 0 — unaware or just exposed
  WORKING       // 1 — can do with help
  PROFICIENT    // 2 — can do independently
  EXPERT        // 3 — can teach others
}

model Skill {
  id           String   @id
  workspaceId  String?  // null = global taxonomy
  slug         String
  name         String
  description  String?
  category     String?  // coarse grouping: "Data", "Communication"
  decayDays    Int?     // re-verification cadence for compliance skills
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace       Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prerequisites   SkillPrerequisite[] @relation("SkillOf")
  dependents      SkillPrerequisite[] @relation("PrereqOf")
  lessonSkills    LessonSkill[]
  assessmentSkills AssessmentSkill[]
  evidence        Evidence[]
  skillStates     SkillState[]
  roleRequirements RoleRequirement[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([category])
}

model SkillPrerequisite {
  id        String @id
  skillId   String  // the skill
  prereqId  String  // required before this one

  skill  Skill @relation("SkillOf", fields: [skillId], references: [id], onDelete: Cascade)
  prereq Skill @relation("PrereqOf", fields: [prereqId], references: [id], onDelete: Cascade)

  @@unique([skillId, prereqId])
}

// Materialised view of a learner's current proficiency per skill.
// Rebuilt from Evidence; cached here for fast reads.
model SkillState {
  id                   String           @id
  userId               String
  skillId              String
  level                ProficiencyLevel @default(NOVICE)
  confidence           Float            @default(0)  // 0-1, Bayesian-ish
  lastEvidenceAt       DateTime?
  nextReverificationAt DateTime?
  updatedAt            DateTime         @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
}

enum EvidenceKind {
  LESSON_COMPLETE
  ASSESSMENT_PASS
  PROJECT_REVIEWED
  LIVE_SESSION_ATTENDED
  PEER_ENDORSED
  MANAGER_ATTESTED
  IMPORTED          // e.g. LinkedIn, external certificate
}

// Immutable ledger of evidence — each row contributes to a SkillState.
model Evidence {
  id           String         @id
  userId       String
  skillId      String
  kind         EvidenceKind
  sourceType   String         // 'assessment' | 'lesson' | 'submission' | ...
  sourceId     String
  levelAwarded ProficiencyLevel
  weight       Float          @default(1.0)
  note         String?
  createdAt    DateTime       @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([userId, skillId])
  @@index([sourceType, sourceId])
}

// ───────────────────────── Content ─────────────────────────

enum PathStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PathKind {
  PATH
  COLLECTION
  COHORT
  COMPLIANCE
}

// A Path is a curated sequence of Lessons and Assessments that move a learner
// across one or more Skills. It is a VIEW, not a container — lessons can live
// in multiple paths.
model Path {
  id          String     @id
  workspaceId String
  slug        String
  title       String
  subtitle    String?
  summary     String?
  heroImage   String?
  kind        PathKind   @default(PATH)
  status      PathStatus @default(DRAFT)
  estimatedMinutes Int?
  level       ProficiencyLevel @default(NOVICE)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       PathItem[]
  enrollments Enrollment[]
  credential  Credential?  @relation("PathCredential")
  assignments Assignment[]

  @@unique([workspaceId, slug])
  @@index([status])
}

enum PathItemKind {
  LESSON
  ASSESSMENT
  PROJECT
  LIVE_SESSION
  RESOURCE     // external link, optional
}

model PathItem {
  id          String       @id
  pathId      String
  order       Int
  kind        PathItemKind
  lessonId    String?
  assessmentId String?
  projectId   String?
  title       String       // denormalised for ordering views
  required    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  path       Path        @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lesson     Lesson?     @relation(fields: [lessonId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  project    ProjectBrief? @relation(fields: [projectId], references: [id])

  @@unique([pathId, order])
  @@index([pathId])
}

model Lesson {
  id          String   @id
  workspaceId String
  slug        String
  title       String
  subtitle    String?
  estimatedMinutes Int @default(5)
  // blocks: typed content blocks (array of { type, ...fields }).
  // See lib/content/blocks.ts for schema. Never raw HTML.
  blocks      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items         PathItem[]
  skills        LessonSkill[]
  lessonProgress LessonProgress[]

  @@unique([workspaceId, slug])
}

model LessonSkill {
  id       String @id
  lessonId String
  skillId  String

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([lessonId, skillId])
}

// ───────────────────────── Assessment ─────────────────────────

enum AssessmentMode {
  PRACTICE
  GRADED
  PROCTORED
  ADAPTIVE
}

enum QuestionKind {
  MCQ_SINGLE
  MCQ_MULTI
  SHORT_ANSWER
  CODE
  ORDER
}

model Assessment {
  id              String         @id
  workspaceId     String
  slug            String
  title           String
  description     String?
  mode            AssessmentMode @default(GRADED)
  passThreshold   Int            @default(70)  // percentage
  timeLimitSec    Int?
  shuffleQuestions Boolean       @default(true)
  attemptsAllowed Int            @default(3)
  negativeMarking Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  questions Question[]
  items     PathItem[]
  attempts  Attempt[]
  skills    AssessmentSkill[]

  @@unique([workspaceId, slug])
}

model AssessmentSkill {
  id              String           @id
  assessmentId    String
  skillId         String
  awardsAtLevel   ProficiencyLevel @default(WORKING)
  weight          Float            @default(1.0)

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, skillId])
}

model Question {
  id           String       @id
  assessmentId String
  order        Int
  kind         QuestionKind
  stem         String       // markdown
  // choices: array of { id, label, isCorrect, explanation? } for MCQ
  // For CODE/SHORT_ANSWER, a rubric JSON lives here.
  payload      Json
  points       Int          @default(1)
  explanation  String?
  version      Int          @default(1)
  skillSlug    String?      // optional primary skill for item analytics
  createdAt    DateTime     @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@index([assessmentId])
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
  EXPIRED
}

model Attempt {
  id           String        @id
  userId       String
  assessmentId String
  status       AttemptStatus @default(IN_PROGRESS)
  startedAt    DateTime      @default(now())
  submittedAt  DateTime?
  scorePct     Int?
  passed       Boolean?
  timeSpentSec Int           @default(0)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@index([userId, assessmentId])
  @@index([status])
}

model Answer {
  id         String  @id
  attemptId  String
  questionId String
  // response shape depends on question kind (string[] of choice ids, or text)
  response   Json
  isCorrect  Boolean?
  pointsEarned Int    @default(0)

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

// ───────────────────────── Projects ─────────────────────────

model ProjectBrief {
  id          String   @id
  workspaceId String
  slug        String
  title       String
  prompt      String   // markdown
  rubric      Json     // array of { criterion, levels: [{ label, points }] }
  createdAt   DateTime @default(now())

  items       PathItem[]
  submissions Submission[]

  @@unique([workspaceId, slug])
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  REVIEWED
  REVISION_REQUESTED
}

model Submission {
  id         String            @id
  projectId  String
  userId     String
  status     SubmissionStatus  @default(DRAFT)
  content    String            // markdown or JSON payload with file links
  attachments Json?
  reviewerId String?
  rubricScore Json?            // { criterion -> points }
  reviewNotes String?
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project ProjectBrief @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, projectId])
}

// ───────────────────────── Enrollment / progress ─────────────────────────

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
  EXPIRED
}

model Enrollment {
  id         String           @id
  userId     String
  pathId     String
  status     EnrollmentStatus @default(ACTIVE)
  assignedId String?          // link to Assignment if top-down assigned
  enrolledAt DateTime         @default(now())
  completedAt DateTime?
  dueAt      DateTime?
  lastActivityAt DateTime?

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  path           Path             @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  assignment     Assignment?      @relation(fields: [assignedId], references: [id])

  @@unique([userId, pathId])
  @@index([status])
}

model LessonProgress {
  id           String    @id
  enrollmentId String
  lessonId     String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  timeSpentSec Int       @default(0)
  lastPosition Int       @default(0) // block index last viewed

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

// ───────────────────────── Assignments (top-down) ─────────────────────────

enum AssignmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
}

model Assignment {
  id           String           @id
  workspaceId  String
  pathId       String
  assignedById String
  assignedToId String
  dueAt        DateTime?
  status       AssignmentStatus @default(PENDING)
  reason       String?          // "Onboarding", "Compliance 2026-Q2"
  compliance   Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  path        Path      @relation(fields: [pathId], references: [id], onDelete: Cascade)
  assignedBy  User      @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedTo  User      @relation("AssignedTo", fields: [assignedToId], references: [id])
  enrollments Enrollment[]

  @@index([workspaceId, status])
  @@index([assignedToId, status])
}

// ───────────────────────── Credentials ─────────────────────────

model Credential {
  id          String   @id
  workspaceId String
  pathId      String?  @unique
  slug        String
  title       String
  description String?
  issuerName  String
  imageUrl    String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  path      Path?     @relation("PathCredential", fields: [pathId], references: [id])
  issued    IssuedCredential[]

  @@unique([workspaceId, slug])
}

model IssuedCredential {
  id            String    @id
  credentialId  String
  userId        String
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  verificationCode String @unique
  revokedAt     DateTime?
  evidenceBlob  Json?     // snapshot of evidence rows at issue time

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ───────────────────────── Learning Record Store (events) ─────────────────────────

// Append-only ledger. All derived state (progress, credentials) comes from here.
// Inspired by xAPI: actor-verb-object-context.
model LrsEvent {
  id          String   @id
  userId      String
  workspaceId String?
  verb        String   // 'started' | 'completed' | 'answered' | 'passed' | 'failed' | 'attempted' | 'reviewed' | 'enrolled' | 'earned'
  objectType  String   // 'lesson' | 'assessment' | 'question' | 'path' | 'credential' | 'project'
  objectId    String
  result      Json?    // { scorePct, durationMs, correct, ... }
  context     Json?    // { pathId, attemptId, ... }
  occurredAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([objectType, objectId])
}

// ───────────────────────── AI tutor ─────────────────────────

model TutorConversation {
  id        String   @id
  userId    String
  lessonId  String?
  pathId    String?
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TutorMessage[]

  @@index([userId])
}

enum TutorRole {
  USER
  ASSISTANT
  SYSTEM
}

model TutorMessage {
  id             String   @id
  conversationId String
  role           TutorRole
  content        String
  tokensIn       Int?
  tokensOut      Int?
  createdAt      DateTime @default(now())

  conversation TutorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
