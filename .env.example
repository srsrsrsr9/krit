# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/krit?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/krit?schema=public"

# Session secret — 32+ chars, random. Generate: openssl rand -hex 32
SESSION_SECRET="replace_me_with_32_bytes_of_entropy_xxxxxxxxxxxxxx"

# OpenRouter (AI tutor). Leave blank to use the canned-fallback path.
# Grab a key at https://openrouter.ai/keys
# Model IDs: https://openrouter.ai/models
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-chat-v3.1"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Feature flags
KRIT_DEV_LOGIN="true"   # enables one-click demo login; disable in prod
